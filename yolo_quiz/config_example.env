# ============================================================================
# 환경 변수 설정 (config_example.env → .env 로 복사 후 수정)
# ============================================================================

# NeonDB 연결
DATABASE_URL=postgresql://username:password@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require

# 파일 저장 경로
PDF_INPUT_DIR=./data/pdfs
IMAGE_OUTPUT_DIR=./data/images
CROP_OUTPUT_DIR=./data/crops

# YOLO 설정
YOLO_MODEL_PATH=./models/yolo_questions.pt
YOLO_CONFIDENCE=0.5

# 서버 설정
API_HOST=0.0.0.0
API_PORT=8000


